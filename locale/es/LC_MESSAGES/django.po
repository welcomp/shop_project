#: templates/oscar/customer/wishlists/wishlists_form.html:33
msgid "What should your new wish list be called?"
msgstr "¿Cómo llamaras tu nueva lista de deseos?"

#: apps/wishlists/abstract_models.py:36
msgid ""
"Shared - Only the owner and people with access to the obfuscated link can "
"see the wish list"
msgstr "Compartida - Visible solo para ti y para quien reciba el enlace privado."

#: templates/oscar/customer/wishlists/wishlists_form.html:38
#, python-format
msgid ""
"\n"
"                    After your wishlist is created, <strong>%(title)s</strong> will be added.\n"
"                "
msgstr "\nDespués de crear la lista de deseos, <strong>%(title)s</strong> será añadido."


#: templates/oscar/customer/wishlists/wishlists_form.html:45
msgid "Share wishlist"
msgstr "Compartir mi lista de deseos"

#: templates/oscar/customer/wishlists/wishlists_form.html:47
msgid ""
"If you want to share your wishlist with others, you can add their email "
"addresses below. The visibility must be set to shared in order for this to "
"work."
msgstr ""
"Para compartir tu lista con otras personas, ingresa sus correos electrónicos "
"aquí abajo. <br><br><strong>Importante:</strong> Asegúrate de que la visibilidad de la lista sea "
"\"Compartida\" para que puedan verla."

